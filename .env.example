# OpenAI-호환 LLM 클라이언트 환경 변수 템플릿.
# 본 파일은 git에 커밋된다. 실제 값은 .env에 복사해서 사용 (.env는 gitignore됨).
#
# OpenAI Python SDK가 아래 변수를 자동 인식하므로 코드는 provider에 무관하다.
# OpenAI 호환 endpoint면 어떤 backend(OpenAI, OpenRouter, Together, Groq,
# 로컬 vLLM 등)든 동일하게 동작한다.

OPENAI_API_KEY=
OPENAI_BASE_URL=
# LLM_MODEL=    # 선택; CLI --model로도 지정 가능